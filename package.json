    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.1",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.15.0",
    "tailwind-merge": "^3.5.0",
